# UMTUBA Mobile — public client environment only
# Copy to `.env` and fill values from the same Supabase project as umtuba-web.
# Never put the Supabase service-role key (or any server secret) in this file.

# Required — Supabase project URL (Dashboard → Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=

# Required — publishable / anon key only (Dashboard → Project Settings → API)
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional — public LiveKit WebSocket URL for a later Live phase (wss://…)
# Do not put LIVEKIT_API_KEY or LIVEKIT_API_SECRET here.
EXPO_PUBLIC_LIVEKIT_URL=

# ---------------------------------------------------------------------------
# Supabase Auth → URL Configuration (Dashboard) — Redirect URLs allowlist
# Add these public patterns before testing password-reset deep links on device
# builds. App scheme is `umtuba` (see app.config.ts). Not secrets.
#   umtuba://auth/update-password
#   umtuba://**
#   https://umtuba.com/**
#   https://www.umtuba.com/**
# Prefer a development/preview build for auth redirects (not Expo Go).
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Push tokens (mobile) — backend table expected by the app (authenticated RLS):
#   public.push_tokens (
#     user_id uuid not null references auth.users(id) on delete cascade,
#     token text primary key,
#     platform text not null,
#     device_id text null,
#     updated_at timestamptz not null default now()
#   )
# RLS: users can insert/update/delete only their own rows.
# The app caches the Expo push token in SecureStore and upserts/deletes via the
# signed-in Supabase session. Never put Expo access tokens or FCM keys here.
# ---------------------------------------------------------------------------
